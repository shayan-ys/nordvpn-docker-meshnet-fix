# Copy to /etc/default/nordvpn-docker-meshnet-fix to override defaults.
# Restart the timer after editing: systemctl restart nordvpn-docker-meshnet-fix.timer

# Docker bridge subnet to allow OUT to Meshnet.
# Find yours with: docker network inspect bridge | jq -r '.[0].IPAM.Config[0].Subnet'
DOCKER_SUBNET=172.18.0.0/16

# NordVPN Meshnet CGNAT range. Don't change unless NordVPN does.
MESHNET_SUBNET=100.64.0.0/10
